---
const links = [
	{ href: '/', label: 'Home' },
	{ href: '/features', label: 'Features' },
	{ href: '/about', label: 'About' },
	{ href: '/news', label: 'News' },
];

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-10">
		<a href="/" class="group flex items-center gap-3" aria-label="Axero AI Home">
			<span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-purple-500 text-lg font-bold text-white">A</span>
			<div class="text-sm font-semibold tracking-[0.18em] text-slate-900">AXERO AI</div>
		</a>
		<nav class="hidden items-center gap-8 md:flex">
			{
				links.map((link) => {
					const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(`${link.href}/`));
					return (
						<a href={link.href} class:list={['nav-link text-sm font-medium text-slate-700 transition hover:text-slate-950', { 'active-link text-slate-950': isActive }] }>
							{link.label}
						</a>
					);
				})
			}
		</nav>
		<a href="/news" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition font-semibold">Explore Updates</a>
	</div>
</header>

<script is:inline>
	const header = document.getElementById('site-header');
	const onScroll = () => {
		if (!header) return;
		header.classList.toggle('nav-scrolled', window.scrollY > 8);
	};
	onScroll();
	window.addEventListener('scroll', onScroll, { passive: true });
</script>
