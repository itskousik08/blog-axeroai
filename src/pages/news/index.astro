---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="News | Axero AI" description="Latest product, research, and ecosystem updates from Axero AI." mainClass="mx-auto max-w-6xl px-6 pb-24 pt-40 lg:px-10">
	<div class="mb-10">
		<p class="mb-4 text-xs font-semibold uppercase tracking-[0.24em] text-indigo-600">Newsroom</p>
		<h1 class="text-5xl font-semibold tracking-tight text-slate-950 sm:text-6xl">Latest Updates</h1>
	</div>
	<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
		{posts.map((post) => (
			<a href={`/news/${post.id}/`} class="rounded-xl border border-slate-200 bg-white p-6 shadow-lg transition hover:-translate-y-1">
				<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><FormattedDate date={post.data.pubDate} /></p>
				<h2 class="mb-3 text-2xl font-semibold text-slate-950">{post.data.title}</h2>
				<p class="text-sm leading-relaxed text-slate-600">{post.data.description}</p>
			</a>
		))}
	</div>
</Layout>
