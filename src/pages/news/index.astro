---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="News | Axero AI" description="Latest product, research, and ecosystem updates from Axero AI." />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-6xl px-6 pb-24 pt-40 lg:px-10">
			<div class="mb-10 flex flex-wrap items-end justify-between gap-4">
				<div>
					<p class="mb-4 text-xs font-semibold uppercase tracking-[0.24em] text-indigo-600">Newsroom</p>
					<h1 class="text-5xl font-semibold tracking-tight text-slate-950">Latest Updates</h1>
				</div>
			</div>
			<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
				{posts.map((post) => (
					<a href={`/news/${post.id}/`} class="rounded-2xl border border-slate-200 bg-white p-6 transition hover:-translate-y-1 hover:shadow-[0_18px_38px_rgba(15,23,42,0.08)]">
						<p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><FormattedDate date={post.data.pubDate} /></p>
						<h2 class="mb-3 text-2xl font-semibold text-slate-950">{post.data.title}</h2>
						<p class="text-sm leading-relaxed text-slate-600">{post.data.description}</p>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
